programa {
  funcao inicio()
	{
		real largura, comprimento, area

		escreva("Digite a largura do galpão (m): ")
		leia(largura)
		escreva("Digite o comprimento do galpão (m): ")
		leia(comprimento)

		area = largura * comprimento

		escreva("A metragem quadrada total do galpão é: ", area, " m².")
	}
}

