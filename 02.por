programa {
 funcao inicio()
	{
		inteiro remessa1, remessa2, estoque_total

		escreva("Quantidade da primeira remessa: ")
		leia(remessa1)
		escreva("Quantidade da segunda remessa: ")
		leia(remessa2)

		estoque_total = remessa1 + remessa2

		escreva("Estoque total disponível: ", estoque_total, " parafusos.")
	}
}

